{
  "name": "neurodiversity-content-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run sync:content && npm run build:web",
    "dev:web": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ingest": "tsx src/server/cli.ts ingest",
    "publish": "tsx src/server/cli.ts publish",
    "sync:content": "npm run ingest && npm run publish"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
